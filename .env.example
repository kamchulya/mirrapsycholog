# Telegram
BOT_TOKEN=your_telegram_bot_token_here

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# База данных
DATABASE_URL=mirra.db

# Часовой пояс
TIMEZONE=Asia/Almaty

# Администратор бота — твой Telegram user_id (узнай у @userinfobot)
ADMIN_ID=your_telegram_user_id

# Твой Telegram username для ручной оплаты (без @)
ADMIN_USERNAME=@твой_username

# Стоимость в Telegram Stars (300 Stars ≈ 3000₸)
STARS_PRICE=300
