# Telegram
BOT_TOKEN=your_telegram_bot_token_here

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI Whisper (для голосового ввода)
# Получи на platform.openai.com → API Keys
# Стоимость: $0.006 за минуту голоса
OPENAI_API_KEY=your_openai_api_key_here

# База данных PostgreSQL (от Railway)
DATABASE_URL=your_postgres_url_here

# Часовой пояс
TIMEZONE=Asia/Almaty

# Администратор (твой Telegram user_id — узнай у @userinfobot)
ADMIN_ID=your_telegram_user_id

# Твой Telegram username для ручной оплаты
ADMIN_USERNAME=@твой_username

# Стоимость в Telegram Stars (300 Stars ≈ 3000₸)
STARS_PRICE=300
